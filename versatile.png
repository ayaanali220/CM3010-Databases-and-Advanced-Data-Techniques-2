\section{Database Connection and Security}

\subsection{Connection Pool}

The \texttt{db.js} module creates a \textbf{connection pool} using
\texttt{mysql2/promise}. A pool pre-establishes a set of reusable database
connections, eliminating the overhead of opening a new TCP connection for every
HTTP request.

\begin{lstlisting}[style=jsstyle,
  caption={Database connection pool --- app/db.js (written personally by Ayaan)},
  label={lst:db}]
'use strict';
const mysql = require('mysql2/promise');

const pool = mysql.createPool({
  host:            process.env.DB_HOST     || 'localhost',
  port:            parseInt(process.env.DB_PORT, 10) || 3306,
  user:            process.env.DB_USER     || 'root',
  password:        process.env.DB_PASSWORD || '',
  database:        process.env.DB_NAME     || 'imdb_coursework',
  waitForConnections: true,
  connectionLimit:    10,
  queueLimit:         0,
});

/** Called at startup to verify DB is reachable before serving traffic */
async function testConnection() {
  try {
    const conn = await pool.getConnection();
    await conn.ping();
    conn.release();
    console.log('Database connection pool established.');
  } catch (err) {
    console.error('Could not connect to database:', err.message);
    process.exit(1);
  }
}

module.exports = { pool, testConnection };
\end{lstlisting}

\subsection{SQL Injection Prevention}

All user-supplied query parameters (e.g., the ``minimum movies'' threshold on the
Genres page) are passed to MySQL as \textbf{parameterised queries} using the
\texttt{?} placeholder syntax provided by \texttt{mysql2}. This completely
prevents SQL injection regardless of what value the user enters.

\begin{lstlisting}[style=jsstyle,
  caption={Parameterised query example --- routes/genres.js (written by Ayaan)}]
router.get('/', async (req, res) => {
  const minMovies = parseInt(req.query.min_movies, 10) || 50;
  //                ^^^^^^^^ parsed to integer; default to 50

  const [rows] = await pool.query(
    `SELECT g.name, COUNT(DISTINCT t.tconst) AS total_movies, ...
     FROM genre g JOIN title_genre tg ON tg.genre_id = g.genre_id
     ...
     HAVING COUNT(DISTINCT t.tconst) >= ?
     ORDER BY avg_rating DESC`,
    [minMovies]          // <-- value injected safely by mysql2
  );

  res.render('genres', { title: 'RQ1', rows, minMovies });
});
\end{lstlisting}

