<%#
  about.ejs — Dataset information & project context
  CM3010 Database Coursework
  Author: Written personally by Ayaan
%>
<%- include('partials/header') %>

<section class="page-hero page-hero--teal">
  <div class="container">
    <p class="label-caps page-hero__tag">About This Project</p>
    <h1 class="page-hero__title">About IMDb Explorer</h1>
    <p class="page-hero__desc">Dataset information, terms of use, and project context.</p>
  </div>
</section>

<section class="content-section">
  <div class="container about-grid">

    <!-- Dataset assessment -->
    <article class="about-card">
      <h2 class="about-card__title">📊 Dataset: IMDb Non-Commercial</h2>
      <p>
        This project uses the
        <a href="https://datasets.imdbws.com/" target="_blank" rel="noopener noreferrer">
          IMDb Non-Commercial Datasets
        </a>
        — a freely available, regularly updated collection of movie data covering titles,
        cast, crew, and user ratings.
      </p>
      <p>Data is filtered to <strong>movies released between 2000 and 2023</strong>.</p>

      <table class="data-table data-table--compact" aria-label="Dataset assessment">
        <caption class="sr-only">Assessment of the IMDb dataset against module criteria</caption>
        <thead>
          <tr><th scope="col">Criterion</th><th scope="col">Assessment</th></tr>
        </thead>
        <tbody>
          <tr><td>Quality</td><td class="gold-text">High — curated and updated weekly by IMDb</td></tr>
          <tr><td>Level of Detail</td><td class="gold-text">High — runtime, crew, ratings, genre per title</td></tr>
          <tr><td>Documentation</td><td class="gold-text">Excellent — full data dictionary at imdb.com/interfaces</td></tr>
          <tr><td>Interrelation</td><td class="gold-text">High — multiple files link via tconst/nconst identifiers</td></tr>
          <tr><td>Discoverability</td><td class="gold-text">Excellent — publicly indexed at datasets.imdbws.com</td></tr>
          <tr><td>Terms of Use</td><td>Non-commercial academic use explicitly permitted</td></tr>
        </tbody>
      </table>
    </article>

    <!-- Research questions summary -->
    <article class="about-card">
      <h2 class="about-card__title">🔬 Research Questions</h2>
      <ol class="about-rq-list">
        <li><a href="/genres">RQ1 — Which genres have the highest average IMDb rating?</a></li>
        <li><a href="/directors">RQ2 — Who are the top 10 directors by average rating (min 5 films)?</a></li>
        <li><a href="/trends">RQ3 — How has average movie rating changed by year (2000–2023)?</a></li>
        <li><a href="/duration">RQ4 — Which genres produce the longest movies on average?</a></li>
        <li><a href="/versatile">RQ5 — Which directors work across the most genres?</a></li>
      </ol>
      <p class="about-note">
        Each question is answered with a parameterised SQL query and presented with
        an interactive data table and Chart.js visualisation.
      </p>
    </article>

    <!-- Database schema summary -->
    <article class="about-card">
      <h2 class="about-card__title">🗄️ Database Schema</h2>
      <p>Six tables in <strong>3NF</strong> normalisation:</p>
      <ul class="schema-list">
        <li><code>title</code> — Core movie metadata (year, runtime, etc.)</li>
        <li><code>genre</code> — Genre lookup table</li>
        <li><code>title_genre</code> — Many-to-many: title ↔ genre</li>
        <li><code>rating</code> — Average rating &amp; vote count per title</li>
        <li><code>person</code> — Cast and crew profiles</li>
        <li><code>principal</code> — Many-to-many: title ↔ person (with role)</li>
      </ul>
    </article>

    <!-- Tech stack -->
    <article class="about-card">
      <h2 class="about-card__title">⚙️ Technology Stack</h2>
      <ul class="schema-list">
        <li><strong>Database:</strong> MySQL (local) via mysql2</li>
        <li><strong>Runtime:</strong> Node.js</li>
        <li><strong>Framework:</strong> Express.js</li>
        <li><strong>Templating:</strong> EJS</li>
        <li><strong>Styling:</strong> Vanilla CSS (Cinematic Scholar design system)</li>
        <li><strong>Charts:</strong> Chart.js v4 (CDN)</li>
        <li><strong>UI Design:</strong> Google Stitch MCP</li>
      </ul>
    </article>

  </div>
</section>

<%- include('partials/footer') %>
